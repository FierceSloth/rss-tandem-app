{
  "name": "rss-tandem",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "lint-staged": {
    "*.{ts,js}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,scss,md,html}": [
      "prettier --write"
    ]
  },
  "validate-branch-name": {
    "pattern": "^(master|main|develop|tandem)$|^(init|feat|fix|docs|refactor|style|chore)/[A-Z]+-[A-Z]+-\\d+_[a-zA-Z][a-zA-Z0-9]*$",
    "errorMsg": "Error: incorrect branch name. Example: feat/RSS-TD-01_implementLoginForm"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "prepare": "husky",
    "format": "prettier --write src",
    "ci:format": "prettier --check src",
    "lint": "eslint src --ext .ts,.js",
    "lint:fix": "eslint src --ext .ts,.js --fix",
    "test": "npm run format && npm run lint:fix && npm run lint && vitest run",
    "vitest": "vitest run"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.0.7",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-unicorn": "^62.0.0",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "sass": "^1.97.2",
    "typescript": "~5.9.3",
    "validate-branch-name": "^1.3.2",
    "vite": "^7.2.4",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.97.0",
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.15",
    "codemirror": "^6.0.2"
  }
}
